# Copy to .env for local development. Never commit .env.
#
# HOST: use 127.0.0.1 locally (AKS uses 0.0.0.0 via ConfigMap)
HOST=127.0.0.1
PORT=8080
MCP_PATH=/mcp

# Azure — populated automatically in AKS by the Workload Identity webhook.
# Locally, leave blank and use `az login` for any Azure calls.
AZURE_CLIENT_ID=
AZURE_TENANT_ID=

# Key Vault — set this locally to fetch secrets via DefaultAzureCredential (az login).
# In k8s this is left unset; secrets are injected as env vars via values.yaml instead.
KEYVAULT_URL=https://variant-internal.vault.azure.net/
